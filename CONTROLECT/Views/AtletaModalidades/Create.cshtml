@model CONTROLECT.Models.AtletaModalidade

@{
    ViewData["Title"] = "Create";
}


<h4>Atleta / Modalidade - Salvar</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="IdAtleta" class="control-label"></label>
                <select asp-for="IdAtleta" class="form-control" asp-items="ViewBag.IdAtleta"></select>
            </div>
            <div class="form-group">
                <label asp-for="IdModalidade" class="control-label"></label>
                <select asp-for="IdModalidade" class="form-control" asp-items="ViewBag.IdModalidade"></select>
            </div>

            <div class="form-group">
                <label asp-for="IdTurno" class="control-label"></label>
                <select asp-for="IdTurno" class="form-control" asp-items="ViewBag.IdTurno"></select>
            </div>

            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Ativo" /> @Html.DisplayNameFor(model => model.Ativo)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="AtividadePrincipal" /> @Html.DisplayNameFor(model => model.AtividadePrincipal)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-info">Voltar</a>
            </div>
        </form>
    </div>
</div>


