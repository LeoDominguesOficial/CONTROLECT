@model CONTROLECT.Models.Presenca

@{
    ViewData["Title"] = "Create";
}

<h4>Lista de Presença - Salvar</h4>


<script src="~/Scripts/jquery-1.10.2.js" type="text/javascript"></script>

<script>

            $(function () {

                $("#ddlatleta").change(function () {

                    var ddlorigem = "#ddlatleta";
                    var url = '@Url.Content("~/")' + "Presencas/ObterModalidadesbyid";

                    $.getJSON(url, { idAtleta: $(ddlorigem).val() }, function (data) {
                        var items = '';
                        $("#ddlModalidade").empty();
                        $.each(data, function (i, row) {
                            items += "<option value = '" + row.value + "'>" + row.text + "</options>";
                        });
                        $("#ddlModalidade").html(items);
                    })

                    url = '@Url.Content("~/")' + "Presencas/ObterProfessoresbyid";
                    $.getJSON(url, { idAtleta: $(ddlorigem).val() }, function (data) {
                        var items = '';
                        $("#ddlProfessor").empty();
                        $.each(data, function (i, row) {
                            items += "<option value = '" + row.value + "'>" + row.text + "</options>";
                        });
                        $("#ddlProfessor").html(items);
                    })
                })
            })

</script>


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="IdAtleta" class="control-label"></label>
                <select id="ddlatleta" asp-for="IdAtleta" class="form-control" asp-items="ViewBag.IdAtleta">
                    <option value="0">Selecionar Atleta</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="IdModalidade" class="control-label"></label>
                <select id="ddlModalidade"  asp-for="IdModalidade" class="form-control" asp-items="ViewBag.IdModalidade"></select>
            </div>
            <div class="form-group">
                <label asp-for="IdProfessor" class="control-label"></label>
                <select id="ddlProfessor" asp-for="IdProfessor" class="form-control" asp-items="ViewBag.IdProfessor"></select>
            </div>

            <div class="form-group">
                <label asp-for="IdTurno" class="control-label"></label>
                <select asp-for="IdTurno" class="form-control" asp-items="ViewBag.IdTurno"></select>
            </div>

            <div class="form-group">
                <label asp-for="DataPresenca" class="control-label"></label>
                <input asp-for="DataPresenca" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="DataPresenca" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-info">Voltar</a>
            </div>

        </form>
    </div>
</div>

