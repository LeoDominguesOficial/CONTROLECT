@model CONTROLECT.Models.Presenca

@{
    ViewData["Title"] = "Create";
}

<h4>Lista de Presença - Salvar</h4>


<script src="~/Scripts/jquery-1.10.2.js" type="text/javascript"></script>

@if (ViewBag.NomesRetorno != null)
{
    <div class="col-md-6" style="text-decoration-color:red; color:red">
        <h2>PRESENÇAS CADASTRADAS:</h2>
    </div>

    foreach (var nome in ViewBag.NomesRetorno)
    {
        <div class="col-md-6" style="text-decoration-color:red; color:red">
            @nome
        </div>
    }
}

