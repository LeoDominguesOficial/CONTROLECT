@model CONTROLECT.Models.ExameFaixa

@{
    ViewData["Title"] = "Create";
}


<h4>Despesa - Salvar</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="NomeExameFaixa" class="control-label"></label>
                <input asp-for="NomeExameFaixa" class="form-control" />
                <span asp-validation-for="NomeExameFaixa" class="text-danger"></span>
            </div>


            <div class="form-group">
                <label asp-for="IdModalidade" class="control-label"></label>
                <select id="ddlModalidade" asp-for="IdModalidade" class="form-control" asp-items="ViewBag.IdModalidade"></select>
            </div>



            <div class="form-group">
                <label asp-for="DataInicial" class="control-label"></label>
                <input asp-for="DataInicial" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="DataInicial" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DataFinal" class="control-label"></label>
                <input asp-for="DataFinal" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="DataFinal" class="text-danger"></span>
            </div>


            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Ativo" /> @Html.DisplayNameFor(model => model.Ativo)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-info">Voltar</a>
            </div>
        </form>
    </div>
</div>

<div>
    
</div>

