    <div class="col-md-4">


        @*<select id="ddlatleta1" asp-for="IdAtleta" class="form-control" asp-items="ViewBag.IdAtleta"></select>*@

        <script src="~/Scripts/jquery-1.10.2.js" type="text/javascript"></script>

