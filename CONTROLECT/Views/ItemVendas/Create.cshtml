@model CONTROLECT.Models.ItemVenda

@{
    ViewData["Title"] = "Create";
}

<h4>Itens da Loja - Salvar</h4>
<hr />

<div class="row">
    <div class="col-md-4">
        
        <form asp-action="Create">


            <div asp-validation-summary="ModelOnly" class="text-danger"></div>


            <div class="form-group">
                <label asp-for="IdItem" class="control-label"></label>
                <select id="ddlItem" asp-for="IdItem" class="form-control" asp-items="ViewBag.IdItem">
                    <option value="0">Selecionar Item</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="Quantidade"></label>
                <input asp-for="Quantidade" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="ValorUnitario"></label>
                <input asp-for="ValorUnitario" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Comprador"></label>
                <input asp-for="Comprador" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="IdFormaPagamento" class="control-label"></label>
                <select asp-for="IdFormaPagamento" class="form-control" asp-items="ViewBag.IdFormaPagamento"></select>
                <span asp-validation-for="IdFormaPagamento" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-info">Voltar</a>
            </div>
        </form>
        
    </div>
</div>

