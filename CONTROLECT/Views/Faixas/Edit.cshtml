@model CONTROLECT.Models.Faixa

@{
    ViewData["Title"] = "Edit";
}

<h4>Faixa - Editar</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdFaixa" />
            <div class="form-group">
                <label asp-for="NomeFaixa" class="control-label"></label>
                <input asp-for="NomeFaixa" class="form-control" />
                <span asp-validation-for="NomeFaixa" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-info">Voltar</a>
            </div>
        </form>
    </div>
</div>



