@model IEnumerable<CONTROLECT.Models.ExameFaixaDetalhe>

@{
    ViewData["Title"] = "Index";
}

<h4>Listagem de Lançamentos de Despesas</h4>

<p>
    <a asp-action="Create" class="btn btn-success btn-sm">Novo</a>
</p>

<form asp-action="Index" method="get">
    <div class="form-actions no-color">
        <p>
            Exame de Faixa: @Html.DropDownList("IdExameFaixa", "--Selecione--")


            <input type="submit" value="Pesquisar" class="btn btn-primary" /> |
            <a asp-action="Index" class="btn btn-outline-primary">Carregar Listagem completa</a>
        </p>
    </div>
</form>


<table id="tblExame" class="table table-striped table-bordered table-sm table w-auto text-xsmall">
    <thead>
        <tr>
            <th>
                Recebimentos
            </th>
            <th>
                Atleta
            </th>
            <th>
                Data Pgto
            </th>
            <th>
                Valor
            </th>
            <th>
                Frm Pgto
            </th>

            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IdExameNavigation.NomeExameFaixa)
            </td>
            <td>
                    @Html.DisplayFor(modelItem => item.IdAtletaNavigation.PrimeiroNome)  @Html.DisplayFor(modelItem => item.IdAtletaNavigation.UltimoNome)

                @* @Html.DisplayFor(modelItem => item.DataPagamento.Day)/@Html.DisplayFor(modelItem =>  item.DataPagamento.Month.ToString("00"))/@Html.DisplayFor(modelItem => item.DataPagamento.Year) *@
@*                 @item.DataPagamento.Day.ToString("00")/@item.DataPagamento.Month.ToString("00")/@item.DataPagamento.Year
 *@
            </td>


            <td>
                @Html.DisplayFor(modelItem => item.DataPagamento)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.Valor)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.IdFormaPagamentoNavigation.NomeFormaPagamento)
            </td>

            <td>
                <a asp-action="Edit" asp-route-id="@item.IdExameFaixaDetalhe" class="btn btn-primary btn-sm">Editar</a> |
                <a asp-action="Details" asp-route-id="@item.IdExameFaixaDetalhe" class="btn btn-info btn-sm">Detalhes</a> |
                <a asp-action="Delete" asp-route-id="@item.IdExameFaixaDetalhe" class="btn btn-danger btn-sm">Excluir</a>

            </td>
        </tr>
}
    </tbody>
</table>
